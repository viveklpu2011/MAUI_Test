                                    </Border>
                                    <Border
                                        BackgroundColor="White"
                                        HeightRequest="24"
                                        Stroke="#E2E8F0"
                                        StrokeShape="RoundRectangle 4"
                                        StrokeThickness="1"
                                        WidthRequest="24">
                                        <Label
                                            FontSize="10"
                                            HorizontalOptions="Center"
