<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI_Test.Components.CardView"
             x:Name="thisCard">

    <Border StrokeThickness="1" 
            Stroke="{Binding CardBorderColor, Source={x:Reference thisCard}}" 
            BackgroundColor="{Binding CardBackgroundColor, Source={x:Reference thisCard}}">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="{Binding CardCornerRadius, Source={x:Reference thisCard}}"/>
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="#0F172A" Offset="0,4" Radius="6" Opacity="0.06"/>
        </Border.Shadow>
        
        <ContentPresenter Padding="{Binding CardPadding, Source={x:Reference thisCard}}"/>
    </Border>
</ContentView>
