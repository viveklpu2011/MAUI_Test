<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MAUI_Test.Components.ListItemView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="thisItem">

    <Grid ColumnDefinitions="80, 40, *" HeightRequest="60">
        <Label
            Grid.Column="0"
            Margin="0,0,10,0"
            FontSize="11"
            HorizontalTextAlignment="End"
            Text="{Binding Time, Source={x:Reference thisItem}}"
            TextColor="{StaticResource TextSecondary}"
            VerticalOptions="Center" />

        <Grid Grid.Column="1" VerticalOptions="Fill">
            <BoxView
                HorizontalOptions="Center"
                IsVisible="{Binding ShowLine, Source={x:Reference thisItem}}"
                VerticalOptions="Fill"
                WidthRequest="2"
                Color="#E2E8F0" />

            <Border
                BackgroundColor="{Binding IconBgColor, Source={x:Reference thisItem}}"
                HeightRequest="30"
                HorizontalOptions="Center"
                StrokeThickness="0"
                VerticalOptions="Center"
                WidthRequest="30">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>
                <Path
                    Aspect="Uniform"
                    Data="{Binding IconData, Source={x:Reference thisItem}}"
                    Fill="{Binding IconColor, Source={x:Reference thisItem}}"
                    HeightRequest="14"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="14" />
            </Border>
        </Grid>

        <VerticalStackLayout
            Grid.Column="2"
            Margin="10,0,0,0"
            Spacing="2"
            VerticalOptions="Center">
            <Label
                FontAttributes="Bold"
                FontSize="13"
                Text="{Binding ItemTitle, Source={x:Reference thisItem}}"
                TextColor="{StaticResource TextPrimary}" />
            <Label
                FontSize="11"
                Text="{Binding ItemDescription, Source={x:Reference thisItem}}"
                TextColor="{StaticResource TextSecondary}" />
        </VerticalStackLayout>
    </Grid>
</ContentView>
