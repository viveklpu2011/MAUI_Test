<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MAUI_Test.Components.SidebarView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:MAUI_Test.ViewModels">

    <Grid
        BackgroundColor="{StaticResource SidebarBg}"
        RowDefinitions="Auto, *"
        WidthRequest="240">
        <HorizontalStackLayout
            Grid.Row="0"
            Padding="20,25"
            Spacing="10"
            VerticalOptions="Center">
            <Path
                Aspect="Uniform"
                Data="M12 2L2 22h20L12 2zm0 3.99L18.8 19H5.2L12 5.99z"
                Fill="White"
                HeightRequest="22"
                WidthRequest="22" />
            <Label
                CharacterSpacing="1.5"
                FontAttributes="Bold"
                FontSize="18"
                Text="DASHBOARD"
                TextColor="White"
                VerticalOptions="Center" />
        </HorizontalStackLayout>

        <ScrollView Grid.Row="1" Margin="0,0,0,10">
            <VerticalStackLayout Padding="10,0" BindableLayout.ItemsSource="{Binding SidebarItems}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:SidebarItem">
                        <Border
                            Margin="5,2"
                            Padding="12,10"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding IsActive}"
                                            TargetType="Border"
                                            Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource SidebarActiveBg}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid ColumnDefinitions="30, *">
                                <Path
                                    Grid.Column="0"
                                    Aspect="Uniform"
                                    Data="{Binding IconData}"
                                    HeightRequest="16"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    WidthRequest="16">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Fill" Value="{StaticResource SidebarTextColor}" />
                                            <Style.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding IsActive}"
                                                    TargetType="Path"
                                                    Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource SidebarActiveTextColor}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>

                                <Label
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    CharacterSpacing="0.5"
                                    FontSize="13"
                                    Text="{Binding Title}"
                                    VerticalOptions="Center">
                                    <Label.Style>
                                        <Style TargetType="Label">
                                            <Setter Property="TextColor" Value="{StaticResource SidebarTextColor}" />
                                            <Style.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding IsActive}"
                                                    TargetType="Label"
                                                    Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource SidebarActiveTextColor}" />
                                                    <Setter Property="FontAttributes" Value="Bold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Label.Style>
                                </Label>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentView>
